<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>Divoom Spike BLE</string>
  <key>CFBundleDisplayName</key><string>Divoom Spike BLE</string>
  <key>CFBundleIdentifier</key><string>com.divoom.spikeble</string>
  <key>CFBundleVersion</key><string>1</string>
  <key>CFBundleShortVersionString</key><string>0.1</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleExecutable</key><string>divoom-spike-ble</string>
  <!-- The TCC grant the whole port hinges on: without this string macOS denies
       CoreBluetooth and the process is killed the first time it touches BLE. -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>Divoom Spike BLE connects to Divoom pixel displays over Bluetooth to validate the native daemon port.</string>
  <key>LSUIElement</key><true/>
</dict>
</plist>
